{
  "name": "beaubremer-weather-bot",
  "version": "2.1.3",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:css": "tailwindcss -i ./src/input.css -o ./style.css",
    "build:css:minify": "tailwindcss -i ./src/input.css -o ./style.css --minify",
    "build:css:silent": "BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i ./src/input.css -o ./style.css",
    "update-browsers": "npx update-browserslist-db@latest --yes"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.3",
    "node-fetch": "^2.7.0",
    "rollup": "^4.34.8",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "ajv": "^8.20.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "js-yaml": "^4.1.1",
    "netlify-cli": "^26.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "ajv": "^8.20.0",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "^6.14.0"
    },
    "esbuild": "^0.28.1",
    "uuid": "^13.0.1",
    "fast-uri": "^3.1.1",
    "minimatch": "^10.2.3",
    "rollup": "^4.34.8",
    "svgo": "^4.0.1",
    "tar": "^7.5.10",
    "picomatch": ">=2.3.2",
    "qs": "^6.15.2",
    "brace-expansion": "^5.0.6",
    "multiparty": "^4.3.0",
    "ws": "^8.20.1",
    "@fastify/static": "^9.1.1",
    "netlify-cli": {
      "esbuild": "^0.28.1",
      "@fastify/static": "^9.1.1",
      "minimatch": "^10.2.3",
      "rollup": "^4.34.8",
      "svgo": "^4.0.1",
      "tar": "^7.5.10",
      "uuid": "^13.0.1",
      "fast-uri": "^3.1.1"
    }
  }
