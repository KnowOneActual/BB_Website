            "mimeType": "application/json",
            "size": 3825,
            "text": "{\n  \"hardware\": [\n    {\n      \"name\": \"MacBook Pro (16-inch) M3 Max\",\n      \"description\": \"My primary machine for development and creative work, running macOS Sequoia.\"\n    },\n    {\n      \"name\": \"Dell Latitude 14\",\n      \"description\": \"Secondary machine running Windows 10 and ParrotOS for critical network/security testing and compatibility checks.\"\n    },\n    {\n      \"name\": \"Focusrite Scarlett 2i2 Audio Interface\",\n      \"description\": \"For high-fidelity audio recording and monitoring.\"\n    }\n  ],\n  \"software\": {\n    \"general\": [\n      {\n        \"name\": \"Browsers: Waterfox, Brave, Firefox, LibreWolf\",\n        \"description\": \"A multi-browser setup for testing and privacy, with Proton Pass for credential management.\"\n      },\n      {\n        \"name\": \"Email: Betterbird\",\n        \"description\": \"An open-source email client derived from Thunderbird, optimized for performance.\",\n        \"url\": \"https://www.betterbird.eu/\"\n      },\n      {\n        \"name\": \"Notes: Notesnook, Obsidian\",\n        \"description\": \"For everything from quick notes to a personal knowledge base.\"\n      },\n      {\n        \"name\": \"Word Processing: LibreOffice, Google Docs, Apple Pages & Numbers\",\n        \"description\": \"Standard document creation and data management.\"\n      }\n    ],\n    \"development\": [\n      {\n        \"name\": \"Text Editors / IDE: Zed, VSCodium, VS Code, BBEdit\",\n        \"description\": \"Optimized for web and Python development. Zed is currently my primary editor for its incredible speed.\",\n        \"url\": \"https://zed.dev/\"\n      },\n      {\n        \"name\": \"Terminal: Ghostty, Warp, kitty\",\n        \"description\": \"Modern and fast terminal emulators. Ghostty is my current favorite for its performance and feature set.\",\n        \"url\": \"https://ghostty.org/\"\n      },\n      {\n        \"name\": \"Virtualization: VMWare Fusion Pro\",\n        \"description\": \"Used since 2009 for running various environments including Win11, ParrotOS, and Ubuntu Server.\"\n      },\n      {\n        \"name\": \"Networking: Wireshark, NMap, Network Triage Tool\",\n        \"description\": \"Essential for deep network troubleshooting and security analysis. My custom Network Triage Tool provides a real-time TUI dashboard for diagnostics.\"\n      }\n    ],\n    \"creative\": [\n      {\n        \"name\": \"Graphics: Affinity Photo, Affinity Designer, Gimp, Inkscape\",\n        \"description\": \"A suite of professional tools for photo editing and vector graphics.\"\n      },\n      {\n        \"name\": \"Video Editing: DaVinci Resolve, LosslessCut\",\n        \"description\": \"High-end post-production and quick lossless clipping.\"\n      },\n      {\n        \"name\": \"3D and CAD: Blender, Freecad\",\n        \"description\": \"For 3D modeling, animation, and technical CAD work.\"\n      },\n      {\n        \"name\": \"Audio: Reaper, Logic Pro, Audacity, iZotope RX\",\n        \"description\": \"Comprehensive audio recording, editing, and restoration.\"\n      }\n    ]\n  },\n  \"live_production\": [\n    {\n      \"name\": \"Show Control & Playback\",\n      \"description\": \"QLab, ProPresenter, Mitti, Companion, and M32-Edit for live event orchestration.\"\n    },\n    {\n      \"name\": \"System Design & Analysis\",\n      \"description\": \"Smaart, MAPP 3D, Wireless Workbench, and Soundbase for audio measurement and RF coordination.\"\n    },\n    {\n      \"name\": \"Video & Lighting Tools\",\n      \"description\": \"Millumin4, Kards, and QLC+ for projection mapping and lighting control.\"\n    }\n  ],\n  \"services\": [\n    {\n      \"name\": \"Netlify\",\n      \"description\": \"Core host for this site; utilizes a seamless Git-based workflow and serverless functions.\"\n    },\n    {\n      \"name\": \"GitHub\",\n      \"description\": \"Version control, project management, and collaboration.\"\n    },\n    {\n      \"name\": \"Cloudflare\",\n      \"description\": \"Edge security, DNS management, and bot protection.\"\n    }\n  ]\n}\n"
