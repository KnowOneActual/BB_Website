          "content": {
            "mimeType": "text/html; charset=UTF-8",
            "size": 28155,
            "text": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta\n      name=\"description\"\n      content=\"Showcasing my background in technical project management and AV/IT system implementation, ensuring seamless functionality and timely delivery in dynamic environments.\"\n    />\n    <title>Beau Bremer | Technical Project & AV/IT Systems Management</title>\n    <link rel=\"me\" href=\"https://mastodon.social/@grimburly\" />\n    <link rel=\"me\" href=\"https://github.com/KnowOneActual\" />\n    <link rel=\"me\" href=\"https://defcon.social/@GrimBurly\" />\n    <link rel=\"canonical\" href=\"https://beaubremer.com/\" />\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"/img/favicon/favicon.svg\" />\n    <link rel=\"icon\" type=\"image/webp\" href=\"/img/favicon/favicon-32x32.webp\" sizes=\"32x32\" />\n    <link rel=\"icon\" type=\"image/webp\" href=\"/img/favicon/favicon-96x96.webp\" sizes=\"96x96\" />\n    <link rel=\"icon\" type=\"image/png\" href=\"/img/favicon/favicon-96x96.png\" sizes=\"96x96\" />\n    <link rel=\"icon\" type=\"image/png\" href=\"/img/favicon/favicon-32x32.png\" sizes=\"32x32\" />\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/img/favicon/apple-touch-icon.png\" />\n    <link rel=\"manifest\" href=\"/img/favicon/site.webmanifest\" />\n    <link rel=\"shortcut icon\" href=\"/img/favicon/favicon.ico\" />\n    <link rel=\"stylesheet\" href=\"fonts.css\" />\n    <script src=\"https://challenges.cloudflare.com/turnstile/v0/api.js\" async defer></script>\n    <link rel=\"stylesheet\" href=\"style.css\" />\n  </head>\n\n  <body class=\"bg-gray-950 text-gray-50 scroll-smooth\">\n    <nav class=\"fixed top-0 w-full z-50 py-6 px-6 transition-all duration-300\">\n      <div class=\"max-w-6xl mx-auto flex justify-between items-center\">\n        <a href=\"#\" class=\"text-xl font-bold tracking-tighter text-indigo-400\">BEAU BREMER</a>\n        <div class=\"hidden md:flex space-x-8 text-sm font-medium\">\n          <a href=\"#about\" class=\"nav-link hover:text-indigo-400 transition\">About</a>\n          <a href=\"#featured-projects\" class=\"nav-link hover:text-indigo-400 transition\">Projects</a>\n          <a class='nav-link hover:text-indigo-400 transition' href='/my_ip'>IP Info </a>\n          <a\n            href=\"https://blog.beaubremer.com/\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"nav-link hover:text-indigo-400 transition\"\n            >Blog</a\n          >\n          <a href=\"#contact\" class=\"nav-link hover:text-indigo-400 transition\">Contact</a>\n        </div>\n        <div class=\"flex items-center space-x-4\">\n          <a\n            href=\"https://github.com/KnowOneActual\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            aria-label=\"GitHub Profile\"\n            class=\"hover:text-indigo-400 transition\"\n          >\n            <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path\n                d=\"M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22v3.293c0 .319.192.694.805.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z\"\n              />\n            </svg>\n          </a>\n          <a\n            href=\"https://www.linkedin.com/in/beau-bremer-chicago/\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            aria-label=\"LinkedIn Profile\"\n            class=\"hover:text-indigo-400 transition\"\n          >\n            <svg class=\"w-6 h-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path\n                d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"\n              />\n            </svg>\n          </a>\n        </div>\n      </div>\n    </nav>\n\n    <main>\n      <section\n        class=\"min-h-screen relative flex items-center justify-center text-center bg-gradient-to-br from-gray-950 via-indigo-950 to-indigo-900 px-6 overflow-hidden\"\n      >\n        <div class=\"relative z-10 space-y-8 max-w-4xl fade-in\">\n          <div class=\"space-y-4\">\n            <h1 class=\"text-5xl md:text-7xl font-extrabold leading-tight text-white tracking-tight\">Beau Bremer</h1>\n            <p class=\"text-xl md:text-2xl font-medium text-indigo-300\">\n              Technical Project Manager & AV/IT Systems Specialist\n            </p>\n          </div>\n\n          <p class=\"text-lg md:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed\">\n            Solving complex tech challenges with a creative, hands-on approach. Expertise in infrastructure, automation,\n            and seamless system integration.\n          </p>\n\n          <div class=\"flex flex-wrap justify-center gap-4 pt-4\">\n            <a\n              href=\"#contact\"\n              class=\"px-8 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-lg transition duration-300 shadow-lg shadow-indigo-600/20\"\n            >\n              Get In Touch\n            </a>\n            <a\n              href=\"#contact\"\n              id=\"request-resume-btn\"\n              class=\"px-8 py-3 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-lg transition duration-300 border border-gray-700 shadow-xl\"\n            >\n              Request Latest Resume\n            </a>\n          </div>\n        </div>\n      </section>\n      <section id=\"about\" class=\"bg-gray-950 py-24 px-6 scroll-mt-20\">\n        <div class=\"max-w-5xl mx-auto\">\n          <h2 class=\"text-4xl font-bold mb-12 text-center fade-in text-white tracking-tight\">About Me</h2>\n          <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-12 items-start fade-in\">\n            <div class=\"lg:col-span-2 space-y-6 text-lg text-gray-300 leading-relaxed\">\n              <p>\n                I'm a tech generalist with a deep-seated passion for ensuring systems run smoothly and efficiently. With\n                a background spanning IT operations, audio-visual technical services, and project management, I bring a\n                highly analytical and solution-oriented approach to complex challenges.\n              </p>\n              <p>\n                I thrive on identifying root causes and implementing lasting solutions. Whether it's coordinating\n                large-scale asset deployments or optimizing network POS systems, my focus is always on delivering\n                tangible results and seamless functionality.\n              </p>\n            </div>\n\n            <div class=\"bg-gray-900 p-8 rounded-2xl border border-gray-800 shadow-xl\">\n              <h3 class=\"text-xl font-bold text-indigo-400 mb-6 uppercase tracking-wider text-sm\">Core Skills</h3>\n              <div class=\"flex flex-wrap gap-2\">\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >Project Management</span\n                >\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >AV/IT Integration</span\n                >\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >Network Analysis</span\n                >\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >Python</span\n                >\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >Troubleshooting</span\n                >\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >Asset Deployment</span\n                >\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >Wireshark</span\n                >\n                <span class=\"px-3 py-1 bg-gray-800 text-indigo-300 rounded-md text-sm border border-gray-700\"\n                  >Automation</span\n                >\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section id=\"featured-projects\" class=\"max-w-6xl mx-auto py-24 px-6 bg-gray-950 scroll-mt-20\">\n        <div class=\"flex flex-col md:flex-row justify-between items-end mb-12 gap-6 fade-in\">\n          <div>\n            <h2 class=\"text-4xl font-bold text-white tracking-tight\">Featured Projects</h2>\n            <p class=\"text-gray-400 mt-2\">A selection of tools and applications I've built.</p>\n          </div>\n          <a\n            href=\"https://github.com/KnowOneActual\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"text-indigo-400 font-semibold hover:text-indigo-300 transition flex items-center gap-2\"\n          >\n            View all on GitHub\n            <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path>\n            </svg>\n          </a>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n          <div\n            class=\"group bg-gray-900 border border-gray-800 p-8 rounded-2xl shadow-xl hover:shadow-indigo-500/10 hover:border-gray-700 transition duration-300 fade-in\"\n          >\n            <div class=\"flex justify-between items-start mb-6\">\n              <h3 class=\"text-2xl font-bold text-white group-hover:text-indigo-400 transition\">\n                Conversational Weather Bot\n              </h3>\n              <span\n                class=\"px-2 py-1 bg-indigo-500/10 text-indigo-400 text-xs font-bold rounded uppercase tracking-wider\"\n                >AI / API</span\n              >\n            </div>\n            <p class=\"text-gray-300 mb-6 leading-relaxed\">\n              An interactive bot using Google's Gemini API for NLP and OpenWeatherMap for live data. Features a\n              serverless architecture for efficient processing.\n            </p>\n            <div class=\"flex flex-wrap gap-2 mb-8\">\n              <span class=\"text-[10px] px-2 py-0.5 bg-gray-800 text-gray-400 rounded border border-gray-700\"\n                >JavaScript</span\n              >\n              <span class=\"text-[10px] px-2 py-0.5 bg-gray-800 text-gray-400 rounded border border-gray-700\"\n                >Netlify Functions</span\n              >\n              <span class=\"text-[10px] px-2 py-0.5 bg-gray-800 text-gray-400 rounded border border-gray-700\"\n                >Gemini AI</span\n              >\n            </div>\n            <div class=\"flex gap-4\">\n              <a class='px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-lg text-sm transition' href='/weather'>Live Demo</a\n              >\n              <a\n                href=\"https://blog.beaubremer.com/posts/idea-to-ai/\"\n                class=\"px-5 py-2 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-lg text-sm transition\"\n                >Case Study</a\n              >\n            </div>\n          </div>\n\n          <div\n            class=\"group bg-gray-900 border border-gray-800 p-8 rounded-2xl shadow-xl hover:shadow-indigo-500/10 hover:border-gray-700 transition duration-300 fade-in\"\n          >\n            <div class=\"flex justify-between items-start mb-6\">\n              <h3 class=\"text-2xl font-bold text-white group-hover:text-indigo-400 transition\">\n                Privacy-First Image Cleaner\n              </h3>\n              <span\n                class=\"px-2 py-1 bg-indigo-500/10 text-indigo-400 text-xs font-bold rounded uppercase tracking-wider\"\n                >Security / Tor</span\n              >\n            </div>\n            <p class=\"text-gray-300 mb-6 leading-relaxed\">\n              A secure utility to strip EXIF metadata from images, hosted on the Tor network. Demonstrates Linux admin,\n              Python/Flask, and Nginx hardening.\n            </p>\n            <div class=\"flex flex-wrap gap-2 mb-8\">\n              <span class=\"text-[10px] px-2 py-0.5 bg-gray-800 text-gray-400 rounded border border-gray-700\"\n                >Python</span\n              >\n              <span class=\"text-[10px] px-2 py-0.5 bg-gray-800 text-gray-400 rounded border border-gray-700\"\n                >Flask</span\n              >\n              <span class=\"text-[10px] px-2 py-0.5 bg-gray-800 text-gray-400 rounded border border-gray-700\">Tor</span>\n              <span class=\"text-[10px] px-2 py-0.5 bg-gray-800 text-gray-400 rounded border border-gray-700\"\n                >Nginx</span\n              >\n            </div>\n            <div class=\"flex gap-4\">\n              <a\n                href=\"https://blog.beaubremer.com/posts/site-into-a-tor-onion-service/\"\n                class=\"px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-lg text-sm transition\"\n                >Read Write-up</a\n              >\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"my_projects\" class=\"max-w-6xl mx-auto py-12 px-6 bg-gray-950\">\n        <h3 class=\"text-xl font-bold text-gray-500 uppercase tracking-widest mb-8 text-center fade-in\">\n          Other Tools & Utilities\n        </h3>\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          <div\n            class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n          >\n            <h4 class=\"text-lg font-bold text-white mb-2\">Network Triage Tool</h4>\n            <p class=\"text-gray-400 text-sm mb-4\">\n              A Python TUI dashboard for real-time diagnostics, streamlining troubleshooting in complex network\n              environments.\n            </p>\n            <a\n              href=\"https://github.com/KnowOneActual/Network-Triage-Tool\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              class=\"text-indigo-400 text-sm font-semibold hover:underline\"\n              >GitHub →</a\n            >\n          </div>\n          <div\n            class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n          >\n            <h4 class=\"text-lg font-bold text-white mb-2\">AV IP Subnet Calculator</h4>\n            <p class=\"text-gray-400 text-sm mb-4\">\n              A specialized utility for mapping high-density AV deployments to specific subnet structures with\n              precision.\n            </p>\n            <a class='text-indigo-400 text-sm font-semibold hover:underline' href='/ip_subnet_calculator'>Launch Tool →</a\n            >\n          </div>\n          <div\n            class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n          >\n            <h4 class=\"text-lg font-bold text-white mb-2\">File Encryption Tool</h4>\n            <p class=\"text-gray-400 text-sm mb-4\">\n              A secure AES-256 CLI utility designed for rapid encryption and decryption of sensitive project assets.\n            </p>\n            <a\n              href=\"https://github.com/KnowOneActual/py_file_encrypt_tool\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              class=\"text-indigo-400 text-sm font-semibold hover:underline\"\n              >GitHub →</a\n            >\n          </div>\n          <div\n            class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n          >\n            <h4 class=\"text-lg font-bold text-white mb-2\">The Labs & Experiments</h4>\n            <p class=\"text-gray-400 text-sm mb-4\">\n              A playground for experimental projects, creative coding, and advanced data visualizations like the Trends\n              Infographic.\n            </p>\n            <a class='text-indigo-400 text-sm font-semibold hover:underline' href='/labs'>Explore the Labs →</a>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"toolbag\" class=\"max-w-6xl mx-auto py-12 px-6 bg-gray-950\">\n        <div\n          class=\"bg-gray-900 border border-gray-800 p-12 rounded-2xl text-center fade-in hover:border-indigo-500/30 transition duration-300\"\n        >\n          <h2 class=\"text-4xl font-bold text-white mb-4\">My Toolbag</h2>\n          <p class=\"text-gray-300 mb-8 max-w-xl mx-auto text-lg leading-relaxed\">\n            A curated look at the hardware, software, and services I use every day to get the job done.\n          </p>\n          <a class='inline-block px-10 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl transition shadow-lg shadow-indigo-600/20' href='/toolbag'>\n            Explore My Full Stack\n          </a>\n        </div>\n      </section>\n      <section id=\"recent-posts\" class=\"max-w-6xl mx-auto py-24 px-6 bg-gray-950\">\n        <div class=\"flex flex-col md:flex-row justify-between items-end mb-12 gap-6 fade-in\">\n          <div>\n            <h2 class=\"text-4xl font-bold text-white tracking-tight\">From the Blog</h2>\n            <p class=\"text-gray-400 mt-2\">Insights, tutorials, and project deep-dives.</p>\n          </div>\n          <a\n            href=\"https://blog.beaubremer.com\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"text-indigo-400 font-semibold hover:text-indigo-300 transition flex items-center gap-2\"\n          >\n            View all posts\n            <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path>\n            </svg>\n          </a>\n        </div>\n        <div id=\"blog-posts-container\" class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n          <!-- Skeletons for loading state -->\n          <div class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl animate-pulse\">\n            <div class=\"h-6 bg-gray-700 rounded w-3/4 mb-4\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-1/2 mb-3\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-full mb-1\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-5/6 mb-4\"></div>\n            <div class=\"h-10 bg-gray-700 rounded-lg w-28 mt-4\"></div>\n          </div>\n          <div class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl animate-pulse\">\n            <div class=\"h-6 bg-gray-700 rounded w-3/4 mb-4\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-1/2 mb-3\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-full mb-1\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-5/6 mb-4\"></div>\n            <div class=\"h-10 bg-gray-700 rounded-lg w-28 mt-4\"></div>\n          </div>\n          <div class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl animate-pulse\">\n            <div class=\"h-6 bg-gray-700 rounded w-3/4 mb-4\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-1/2 mb-3\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-full mb-1\"></div>\n            <div class=\"h-4 bg-gray-700 rounded w-5/6 mb-4\"></div>\n            <div class=\"h-10 bg-gray-700 rounded-lg w-28 mt-4\"></div>\n          </div>\n        </div>\n      </section>\n\n      <section id=\"creative_library\" class=\"bg-gray-950 py-24 px-6\">\n        <div class=\"max-w-4xl mx-auto\">\n          <h2 class=\"text-4xl font-bold mb-4 text-center text-white tracking-tight fade-in\">Resource Library</h2>\n          <p class=\"text-center text-gray-400 mb-12 fade-in\">A curated collection of my favorite tools and guides.</p>\n          <ul class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            <li\n              class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n            >\n              <a\n                href=\"/assets/downloads/pdf/Wireshark_Quick_Start_Guide.pdf\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                class=\"text-lg font-bold text-white hover:text-indigo-400 transition\"\n                >Wireshark Quick Start Guide (PDF)</a\n              >\n              <p class=\"text-gray-400 mt-2 text-sm\">\n                Get up and running with Wireshark and learn essential commands for network analysis.\n              </p>\n            </li>\n            <li\n              class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n            >\n              <a\n                href=\"/assets/downloads/pdf/A_Simple_Guide_to_Creating_Gmail_Filters_for_Spam.pdf\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                class=\"text-lg font-bold text-white hover:text-indigo-400 transition\"\n                >Gmail Spam Filter Guide (PDF)</a\n              >\n              <p class=\"text-gray-400 mt-2 text-sm\">\n                A straightforward guide to setting up Gmail filters to manage unwanted emails.\n              </p>\n            </li>\n            <li\n              class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n            >\n              <a\n                href=\"https://coolors.co/\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                class=\"text-lg font-bold text-white hover:text-indigo-400 transition\"\n                >Coolors</a\n              >\n              <p class=\"text-gray-400 mt-2 text-sm\">Quickly generate beautiful color palettes for your projects.</p>\n            </li>\n            <li\n              class=\"p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/30 transition duration-300 fade-in\"\n            >\n              <a\n                href=\"https://feathericons.com/\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                class=\"text-lg font-bold text-white hover:text-indigo-400 transition\"\n                >Feather Icons</a\n              >\n              <p class=\"text-gray-400 mt-2 text-sm\">A collection of simply beautiful open-source icons.</p>\n            </li>\n          </ul>\n        </div>\n      </section>\n\n      <section class=\"py-24 px-6 max-w-4xl mx-auto\">\n        <h2 class=\"text-4xl font-bold mb-12 text-center text-white tracking-tight fade-in\">Testimonials</h2>\n        <div class=\"space-y-8\">\n          <blockquote class=\"bg-gray-900 p-8 rounded-xl border border-gray-800 shadow-xl fade-in\">\n            <p class=\"text-lg italic text-gray-300\">\n              \"Beau brought energy and originality to our project that we didn't even know we needed.\"\n            </p>\n            <cite class=\"mt-4 not-italic font-bold text-gray-400 block\"\n              >– Felix D., Creative Director, Indie Studio</cite\n            >\n          </blockquote>\n          <blockquote class=\"bg-gray-900 p-8 rounded-xl border border-gray-800 shadow-xl fade-in\">\n            <p class=\"text-lg italic text-gray-300\">\n              \"Not only did he deliver, he made the whole process smooth. And the event went killer.\"\n            </p>\n            <cite class=\"mt-4 not-italic font-bold text-gray-400 block\">– Wanda C., Startup Co-Founder</cite>\n          </blockquote>\n        </div>\n      </section>\n      <section id=\"contact\" class=\"bg-gray-950 py-24 px-6\">\n        <div class=\"max-w-2xl mx-auto text-center\">\n          <h2 class=\"text-4xl font-bold text-white tracking-tight mb-4 fade-in\">Get In Touch</h2>\n          <p class=\"text-gray-400 mb-10 fade-in\">Have a question or a project in mind? Let's talk.</p>\n          <form\n            name=\"contact\"\n            data-netlify=\"true\"\n            netlify-honeypot=\"bot-field\"\n            class=\"space-y-6 bg-gray-900 p-8 rounded-2xl border border-gray-800 shadow-2xl fade-in\"\n          >\n            <input type=\"hidden\" name=\"form-name\" value=\"contact\" />\n            <div hidden>\n              <label\n                >Don’t fill this out:\n                <input name=\"bot-field\" />\n              </label>\n            </div>\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n              <input\n                type=\"text\"\n                name=\"name\"\n                placeholder=\"Your Name\"\n                required\n                class=\"w-full p-4 rounded-lg bg-gray-800 text-white border border-gray-700 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition\"\n              />\n              <input\n                type=\"email\"\n                name=\"email\"\n                placeholder=\"Your Email\"\n                required\n                class=\"w-full p-4 rounded-lg bg-gray-800 text-white border border-gray-700 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition\"\n              />\n            </div>\n            <textarea\n              name=\"message\"\n              placeholder=\"Your Message\"\n              rows=\"5\"\n              required\n              class=\"w-full p-4 rounded-lg bg-gray-800 text-white border border-gray-700 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition\"\n            ></textarea>\n            <div class=\"cf-turnstile\" data-sitekey=\"0x4AAAAAABgkt_RFOUv2GXeS\"></div>\n            <button\n              type=\"submit\"\n              class=\"w-full px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-lg transition duration-300 shadow-lg shadow-indigo-600/20\"\n            >\n              Send Message\n            </button>\n          </form>\n        </div>\n      </section>\n    </main>\n    <footer class=\"text-center py-10 bg-gray-950 text-gray-400 border-t border-gray-800\">\n      <div class=\"mb-4\">\n        <a\n          href=\"https://blog.beaubremer.com/\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"hover:text-indigo-400 mx-3 transition\"\n          >Blog</a\n        >\n        <a\n          href=\"https://github.com/KnowOneActual\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"hover:text-indigo-400 mx-3 transition\"\n          >GitHub</a\n        >\n        <a class='hover:text-indigo-400 mx-3 transition' href='/technology_security'>Site Technology Report</a>\n        <a class='hover:text-indigo-400 mx-3 transition' href='/privacy'>Privacy Policy</a>\n      </div>\n      <p class=\"text-gray-400 text-sm\">Handcrafted by me 