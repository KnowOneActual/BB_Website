{
  "name": "beaubremer-weather-bot",
  "version": "1.0.0",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:css": "tailwindcss -i ./src/input.css -o ./style.css",
    "build:css:minify": "tailwindcss -i ./src/input.css -o ./style.css --minify",
    "build:css:silent": "BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i ./src/input.css -o ./style.css",
    "update-browsers": "npx update-browserslist-db@latest --yes"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.3",
    "node-fetch": "^2.7.0",
    "rollup": "^4.34.8",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "js-yaml": "^4.1.1",
    "netlify-cli": "^24.9.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "ajv": "^8.17.1",
    "minimatch": "^10.2.3",
    "rollup": "^4.34.8",
    "svgo": "^4.0.2",
    "tar": "^7.5.10",
    "qs": "6.14.1",
    "netlify-cli": {
      "minimatch": "^10.2.3",
      "rollup": "^4.34.8",
      "svgo": "^4.0.2",
      "tar": "^7.5.10"
    }
  }
}
