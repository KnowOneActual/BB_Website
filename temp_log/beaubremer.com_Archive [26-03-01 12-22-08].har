            "text": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>404 - Page Not Found | Beau Bremer</title>\n    <link rel=\"stylesheet\" href=\"style.css\" />\n    <link href=\"fonts.css\" rel=\"stylesheet\" crossorigin=\"anonymous\" />\n  </head>\n\n  <body class=\"bg-gray-950 text-gray-50 flex items-center justify-center min-h-screen\">\n    <section class=\"max-w-2xl px-6 py-12 text-center\">\n      <div class=\"relative mb-8\">\n        <h1 class=\"text-[12rem] font-extrabold text-gray-900 leading-none select-none\">404</h1>\n        <div class=\"absolute inset-0 flex items-center justify-center\">\n          <div class=\"text-5xl md:text-6xl font-extrabold text-indigo-500 tracking-tighter\">LOST AT SEA</div>\n        </div>\n      </div>\n\n      <div class=\"space-y-6\">\n        <p class=\"text-xl md:text-2xl text-gray-400 max-w-md mx-auto leading-relaxed\">\n          The page you're looking for has drifted off course or never existed in this dimension.\n        </p>\n\n        <div class=\"pt-8 flex flex-wrap justify-center gap-4\">\n          <a class='px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl transition duration-300 shadow-lg shadow-indigo-600/20' href='/'>\n            Return to Home\n          </a>\n          <a class='px-8 py-4 bg-gray-800 hover:bg-gray-700 text-white font-bold rounded-xl transition duration-300 border border-gray-700' href='/toolbag'>\n            Check my Toolbag\n          </a>\n        </div>\n      </div>\n    </section>\n\n    <footer class=\"fixed bottom-0 w-full text-center py-8 text-gray-600 text-xs\">\n      <p>&copy; 2026 Beau Bremer. Stay bold.</p>\n    </footer>\n  </body>\n</html>\n"
