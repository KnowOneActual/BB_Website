            "text": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Beau Bremer | Toolbag</title>\n    <link rel=\"stylesheet\" href=\"style.css\" />\n    <link href=\"fonts.css\" rel=\"stylesheet\" crossorigin=\"anonymous\" />\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css\" />\n  </head>\n\n  <body class=\"bg-gray-950 text-gray-50 scroll-smooth\">\n    <nav\n      class=\"fixed top-0 w-full z-50 py-6 px-6 bg-gray-950/80 backdrop-blur-md border-b border-gray-800 transition-all duration-300\"\n    >\n      <div class=\"max-w-6xl mx-auto flex justify-between items-center\">\n        <a class='text-xl font-bold tracking-tighter text-indigo-400' href='/'>BEAU BREMER</a>\n        <div class=\"hidden md:flex space-x-8 text-sm font-medium\">\n          <a class='nav-link hover:text-indigo-400 transition' href='/#about'>About</a>\n          <a class='nav-link hover:text-indigo-400 transition' href='/#featured-projects'>Projects</a>\n          <a class='nav-link hover:text-indigo-400 transition' href='/my_ip'>IP Info</a>\n          <a\n            href=\"https://blog.beaubremer.com/\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"nav-link hover:text-indigo-400 transition\"\n            >Blog</a\n          >\n          <a class='nav-link hover:text-indigo-400 transition' href='/#contact'>Contact</a>\n        </div>\n        <div class=\"flex items-center space-x-4\">\n          <a\n            href=\"https://github.com/KnowOneActual\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            aria-label=\"GitHub Profile\"\n            class=\"hover:text-indigo-400 transition\"\n          >\n            <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path\n                d=\"M12 0c-